rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Lock down user collections to the authenticated owner only
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // Restrict all subcollections (workouts, daily_metrics, scans) to the authenticated owner
      match /{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Allow authenticated users to read and write shared global product scan records (cache)
    match /{collectionName}/{barcode} {
      allow read, write: if request.auth != null && (
        collectionName == 'global_food_scans' ||
        collectionName == 'global_supplement_scans' ||
        collectionName == 'global_skincare_scans' ||
        collectionName == 'global_vision_food_scans' ||
        collectionName == 'global_vision_supplement_scans' ||
        collectionName == 'global_vision_skincare_scans'
      );
    }
  }
}
