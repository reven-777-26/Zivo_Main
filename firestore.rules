rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Lock down user collections to the authenticated owner only
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // Restrict all subcollections (workouts, daily_metrics, scans) to the authenticated owner
      match /{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
  }
}
